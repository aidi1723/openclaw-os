{
  "name": "agentcore-os",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20 <24"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next-dev',{recursive:true,force:true});\" && next dev -p 3000",
    "build": "next build",
    "build:desktop-web": "node scripts/desktop-runtime/build-static.mjs",
    "desktop:build-doctor": "node scripts/desktop-runtime/build-doctor.mjs",
    "desktop:build-sidecar": "node scripts/desktop-runtime/build-lobster-sidecar.mjs",
    "desktop:package": "node scripts/desktop-runtime/package-desktop.mjs",
    "desktop:prepare-sidecar": "node scripts/desktop-runtime/prepare-lobster-sidecar.mjs",
    "desktop:stage-sidecar": "node scripts/desktop-runtime/stage-lobster-sidecar.mjs",
    "desktop:smoke-test-sidecar": "node scripts/desktop-runtime/smoke-test-sidecar.mjs",
    "tauri": "node scripts/desktop-runtime/run-tauri.mjs",
    "tauri:dev": "node scripts/desktop-runtime/run-tauri.mjs dev",
    "tauri:build": "node scripts/desktop-runtime/run-tauri.mjs build",
    "start": "next start",
    "stable": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\" && next build && next start -p 3000",
    "lint": "next lint",
    "webhook:dev": "node scripts/webhook-connector/server.mjs",
    "publish-queue:worker": "node scripts/publish-queue-worker.mjs",
    "runtime:doctor": "node scripts/desktop-runtime/doctor.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
